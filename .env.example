# Agile Business — Environment Variables
# Скопируйте в .env и заполните реальными значениями.
# ВСЕ переменные с пометкой (ОБЯЗАТЕЛЬНО) должны быть заданы.

# Application
DEBUG=false
# (ОБЯЗАТЕЛЬНО) python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
DOMAIN=example.com

# Database
# (ОБЯЗАТЕЛЬНО) Пароль PostgreSQL (подставляется в URL). Символы @ # % : / ? ломают URL —
#   задайте пароль без них или закодируйте (например @ → %40) вручную в своей строке подключения.
DB_PASSWORD=
# Строка подключения конструируется автоматически в docker-compose

# Redis
# (ОБЯЗАТЕЛЬНО) Пароль Redis
REDIS_PASSWORD=

# S3 / MinIO
# (ОБЯЗАТЕЛЬНО)
MINIO_USER=
MINIO_PASSWORD=

# Elasticsearch (docker-compose.yml; см. также docker-compose.prod.yml без ES для слабых VPS)
# На Linux-хосте при ошибке bootstrap: sudo sysctl -w vm.max_map_count=262144
ELASTIC_PASSWORD=changeme

# CORS — JSON-массив origin фронта (без слэша в конце).
# При DEBUG=false включён CSRF: origin браузера должен совпадать с одним из значений (иначе «CSRF: недопустимый origin»).
# Локально — порты Vite; в проде обязательно добавьте, например: "https://app.example.com"
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://127.0.0.1:5173","http://127.0.0.1:5174"]

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# Telegram Bot (опционально)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Spotify API (опционально)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Sentry (опционально)
SENTRY_DSN=

# Admin seed — задайте при первом запуске, потом уберите
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=

# Uvicorn workers
WORKERS=2

# Порт фронтенда
FRONTEND_PORT=3000

# Заявки с сайта (POST /api/applications/webhook). Пусто = webhook отключён (403).
WEBSITE_WEBHOOK_SECRET=
# Email пользователя с ролью consultant — заявки с сайта сразу закрепляются за ним (пусто = без назначения).
WEBSITE_DEFAULT_CONSULTANT_EMAIL=
