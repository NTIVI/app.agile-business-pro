# ============================================================
# Agile Business — Production (VPS с PostgreSQL)
# Скопируйте в .env перед деплоем: cp .env.production.example .env
# ============================================================

DEBUG=false
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Домен поддомена (для CORS и настроек)
DOMAIN=app.agile-business-pro.com

# Database PostgreSQL (генерируются при первом деплое)
DB_PASSWORD=

# Redis
REDIS_PASSWORD=

# MinIO
MINIO_USER=agile-minio
MINIO_PASSWORD=

# Порт фронтенда (80 для HTTP, 443 через reverse proxy)
FRONTEND_PORT=80

# CORS — домены, с которых разрешены запросы
CORS_ORIGINS=["https://app.agile-business-pro.com","http://app.agile-business-pro.com"]

# Admin (изменить после первого входа!)
ADMIN_SEED_EMAIL=admin@agile.com
ADMIN_SEED_PASSWORD=

# Telegram (опционально)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
