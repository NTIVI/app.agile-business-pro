# Конфиг только для slowapi (не подмешивать server/.env — там могут появиться RATELIMIT_*).
#
# ВАЖНО: slowapi/Starlette не всегда корректно кастит строку "false" в bool,
# из-за этого значение становится truthy и slowapi продолжает пытаться вставлять headers.
# Поэтому оставляем значение пустым: '' будет falsy.
RATELIMIT_HEADERS_ENABLED=
