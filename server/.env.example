# ===== Agile Business — Настройки =====
# Скопируйте этот файл: copy .env.example .env
# Заполните обязательные поля (помечены *)

# --- Приложение ---
DEBUG=true
# В DEBUG можно оставить пустым — подставится фиксированный dev-ключ (сессии переживут перезапуск API).
# В продакшне обязательно задайте случайную строку ≥32 символов и держите её стабильной между деплоями.
SECRET_KEY=
DOMAIN=localhost

# При DEBUG=true новые пользователи сразу ACTIVE (удобно локально). В проде при DEBUG=false — модерация.
# Чтобы на проде разрешить вход сразу после регистрации без DEBUG, выставьте true (осознанно: спам-риск).
REGISTRATION_AUTO_APPROVE=false

# --- * База данных (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://agile:agile_pass@localhost:5432/agile_db

# --- * Redis ---
REDIS_URL=redis://localhost:6379/0

# --- S3 / MinIO (необязательно) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=agile-files

# --- Админ-аккаунт (создаётся при первом запуске) ---
ADMIN_SEED_EMAIL=admin@agile.com
ADMIN_SEED_PASSWORD=Admin!Agile(Secured

# --- CORS + CSRF (при DEBUG=false каждый POST проверяется по этому списку) ---
# Локально: порты Vite. Прод: точный публичный URL без слэша в конце, например:
# CORS_ORIGINS=["https://app.example.com","http://app.example.com"]
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174"]

# --- Telegram Bot (необязательно) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# --- Email / SMTP (необязательно) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# --- Spotify (необязательно) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Sentry (необязательно) ---
SENTRY_DSN=

# --- Заявки с сайта (POST /api/applications/webhook) ---
# WEBSITE_WEBHOOK_SECRET=  # пусто = webhook отключён
# Заявки с сайта без закреплённого консультанта видят все пользователи с ролью consultant.
