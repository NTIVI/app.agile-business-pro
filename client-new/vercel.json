{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://app-agile-business-pro.onrender.com/api/:path*"
    },
    {
      "source": "/ws/:path*",
      "destination": "https://app-agile-business-pro.onrender.com/ws/:path*"
    },
    {
      "source": "/((?!api|ws|assets|favicon.ico|index.html|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
